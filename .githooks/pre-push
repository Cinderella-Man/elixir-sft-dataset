#!/usr/bin/env bash
# Pre-push gate (docs/10 R11): fast local CI.
#
# Install once:  git config core.hooksPath .githooks
#
# Runs mix test always, plus the perfect+mutant validate gates scoped to the
# task families touched by the commits being pushed. A full-corpus sweep stays
# a manual/nightly job (~10 min) — this hook aims for < 2 min.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "[pre-push] mix format --check-formatted && mix compile --warnings-as-errors && mix test"
# lib/test formatting: CI's first step; was missing here, so hand-written lib
# code reached CI unformatted (2026-07-12, 11 files).
mix format --check-formatted
mix compile --warnings-as-errors >/dev/null
mix test >/dev/null

# Families touched between the remote tip and HEAD (fall back to HEAD~10 when
# the remote ref is unknown, e.g. first push of a branch).
range="@{upstream}..HEAD"
git rev-parse --abbrev-ref '@{upstream}' >/dev/null 2>&1 || range="HEAD~10..HEAD"

# head must NOT sit inside the pipeline: with a large diff (e.g. the 957-dir
# bugfix mint) it closes the pipe early, sort dies of SIGPIPE, and pipefail
# kills the whole hook with no output (found live 2026-07-13).
all_families=$(git diff --name-only "$range" -- tasks/ 2>/dev/null |
  sed -E 's#^tasks/(wt_|tfim_|bugfix_|repair_|adapt_|dedoc_|style_|dialog_|tdd_|specfim_)?([0-9]+_[0-9]+).*#\2#' | sort -u)
# herestring, not a pipe: `printf | head` re-created the SIGPIPE-under-pipefail
# death the comment above describes once the dedoc mint pushed ~960 paths
# through here (found live 2026-07-19, hook died silently with rc=141).
families=$(head -20 <<< "$all_families")

# The cap keeps the hook <2min, but it must never truncate SILENTLY: a
# >20-family push left bugfix_109_001's failing children unvalidated on
# 2026-07-22 (caught by the nightly backstop the next morning).
if [ -n "$all_families" ]; then
  total=$(wc -l <<< "$all_families")
  capped=$(wc -l <<< "$families")
  if [ "$total" -gt "$capped" ]; then
    echo "[pre-push] WARNING: $total families touched — perfect/mutant validate" \
      "covers only the first $capped; $((total - capped)) families ride on the" \
      "nightly full sweep as their only backstop"
  fi
fi

if [ -n "$families" ]; then
  globs=$(echo "$families" | sed 's/.*/*&*/' | paste -sd, -)
  echo "[pre-push] validate touched families: $globs"
  elixir scripts/validate.exs --only "$globs" | tail -1
  elixir scripts/validate.exs --mutants --only "$globs" | tail -1
  # Corpus-wide, not family-scoped: CI runs this gate unscoped, and the
  # family cap above (head -20) let 104 deviating embeds reach a green local
  # push and a red CI on 2026-07-19. The gate is cheap CPU — no reason to
  # check less than CI does.
  echo "[pre-push] format check (corpus-wide, matching CI)"
  elixir scripts/format_corpus.exs --check | tail -1
  # Corpus-wide, matching CI (same reasoning as the format gate above): this
  # was the ONE CI embed gate missing here, and 53 drifted module-FIM prompts
  # from 8 hand-fixed families reached a green local push and a red CI on
  # 2026-07-22.
  echo "[pre-push] module-FIM/wt_ fence check (corpus-wide, matching CI)"
  embeds_out=$(elixir scripts/check_embeds.exs)
  echo "$embeds_out" | tail -1
  if ! echo "$embeds_out" | grep -q "^embed check: .*, 0 reflow, 0 drift, "; then
    echo "[pre-push] FAIL: module-FIM/wt_ fences drifted —" \
      "see the scripts/resync_embeds.exs header for the scoped remediation flow"
    exit 1
  fi
  # Corpus-wide, matching CI (same reasoning as the format/embeds gates):
  # the dry run is pure file reads, and the --only scope inherits the
  # 20-family cap above — exactly how the stale bugfix_109_001 golds slipped
  # through on 2026-07-22. Also checks GOLD IDENTITY (child solution.ex ==
  # parent reference); stale_gold is never --apply-healable — re-mint.
  echo "[pre-push] bugfix embed staleness + gold-identity check (corpus-wide, matching CI)"
  bugfix_out=$(mix run scripts/resync_bugfix_embeds.exs || true)
  echo "$bugfix_out" | tail -1
  if echo "$bugfix_out" | grep -q "would_resync\|stale_gold\|error"; then
    echo "[pre-push] FAIL: bugfix prompts embed a stale parent spec or a stale gold —"
    echo "  spec drift: mix run scripts/resync_bugfix_embeds.exs -- --apply"
    echo "  stale gold: delete the pair + re-mint (GEN_ONLY=topup mix run scripts/generate.exs <idea>)"
    exit 1
  fi

  echo "[pre-push] temp-path lint (parallel-eval collisions)"
  mix run scripts/lint_temp_paths.exs

  echo "[pre-push] S6 freshness (blind verdicts must match current harnesses)"
  mix run scripts/check_screen_freshness.exs

  echo "[pre-push] wt_ spec/harness staleness check (all wt_ dirs)"
  wt_out=$(mix run scripts/resync_embeds.exs -- --wt-all)
  echo "$wt_out" | tail -1
  if echo "$wt_out" | grep -q "would_resync\|error"; then
    echo "[pre-push] FAIL: wt_ dirs drifted from their parents —" \
      "run: mix run scripts/resync_embeds.exs -- --wt-all --apply"
    exit 1
  fi

  echo "[pre-push] tfim embed staleness check on touched families"
  resync_out=$(mix run scripts/resync_tfim_embeds.exs -- --only "$globs")
  echo "$resync_out" | tail -1
  if echo "$resync_out" | grep -q "would_resync\|error"; then
    echo "[pre-push] FAIL: tfim prompt embeds drifted from their parents —" \
      "run: mix run scripts/resync_tfim_embeds.exs -- --only \"$globs\" --apply"
    exit 1
  fi

  echo "[pre-push] adapt_ embed staleness check on touched families"
  adapt_out=$(mix run scripts/resync_adapt_embeds.exs -- --only "$globs")
  echo "$adapt_out" | tail -1
  if echo "$adapt_out" | grep -q "would_resync\|error"; then
    echo "[pre-push] FAIL: adapt_ dirs drifted from their parents —" \
      "run: mix run scripts/resync_adapt_embeds.exs -- --only \"$globs\" --apply"
    exit 1
  fi

  echo "[pre-push] dedoc_ embed staleness check on touched families"
  dedoc_out=$(mix run scripts/resync_dedoc_embeds.exs -- --only "$globs")
  echo "$dedoc_out" | tail -1
  if echo "$dedoc_out" | grep -q "would_resync\|error"; then
    echo "[pre-push] FAIL: dedoc_ dirs drifted from their parents —" \
      "run: mix run scripts/resync_dedoc_embeds.exs -- --only \"$globs\" --apply"
    exit 1
  fi

  echo "[pre-push] sfim spec-embed staleness check on touched families"
  sfim_out=$(mix run scripts/resync_sfim_specs.exs -- --only "$globs")
  echo "$sfim_out" | tail -1
  if echo "$sfim_out" | grep -q "would_resync\|ERROR"; then
    echo "[pre-push] FAIL: sfim children embed a stale parent spec —" \
      "run: mix run scripts/resync_sfim_specs.exs -- --only \"$globs\" --apply"
    exit 1
  fi

  echo "[pre-push] tdd_ staleness check on touched families"
  tdd_out=$(mix run scripts/resync_tdd_embeds.exs -- --only "$globs")
  echo "$tdd_out" | tail -1
  if echo "$tdd_out" | grep -q "would_resync\|ERROR"; then
    echo "[pre-push] FAIL: tdd_ dirs drifted from their parents —" \
      "run: mix run scripts/resync_tdd_embeds.exs -- --only \"$globs\" --apply"
    exit 1
  fi

  echo "[pre-push] specfim_ staleness check on touched families"
  specfim_out=$(mix run scripts/resync_specfim_embeds.exs -- --only "$globs")
  echo "$specfim_out" | tail -1
  if echo "$specfim_out" | grep -q "would_resync\|ERROR"; then
    echo "[pre-push] FAIL: specfim_ dirs drifted from their parents —" \
      "run: mix run scripts/resync_specfim_embeds.exs -- --only \"$globs\" --apply"
    exit 1
  fi

  echo "[pre-push] bundle-FIM staleness check on touched families"
  bfim_out=$(mix run scripts/resync_bundlefim_embeds.exs -- --only "$globs")
  echo "$bfim_out" | tail -1
  if echo "$bfim_out" | grep -q "would_resync\|ERROR"; then
    echo "[pre-push] FAIL: bundle-FIM dirs drifted from their parents —" \
      "run: mix run scripts/resync_bundlefim_embeds.exs -- --only \"$globs\" --apply"
    exit 1
  fi
else
  echo "[pre-push] no task families touched — skipping corpus gates"
fi

echo "[pre-push] OK"
