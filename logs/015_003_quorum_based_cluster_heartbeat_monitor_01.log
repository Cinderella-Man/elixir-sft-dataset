<file path="solution.ex">
defmodule ClusterMonitor do
  @moduledoc """
  A singleton `GenServer` that monitors registered **clusters** and decides each
  cluster's `:up`/`:down` status by **quorum**.

  A cluster is a group of independent, zero-arity endpoint check functions. On every
  poll the monitor calls **all** of a cluster's endpoints, counts how many returned
  `:ok`, and recomputes the status fresh: the cluster is `:up` when the healthy count
  is at least the configured quorum, otherwise `:down`. There is no running
  consecutive-failure counter — each poll stands on its own.

  The process registers itself under the name `ClusterMonitor` so that the
  no-argument convenience API (`register_cluster/4`, `poll/1`, `cluster_state/1`,
  `snapshot/0`, `unregister/1`) can locate it without a server reference.

  Polling is periodic via `Process.send_after/3`, with each poll re-scheduling the
  next. Every registration is tagged with a generation token; scheduled poll messages
  whose token no longer matches the current registration are ignored, so superseded
  timer chains (from re-registration or removal) are effectively dead.

  Only the OTP standard library is used; there are no external dependencies.
  """

  use GenServer

  @typedoc "A cluster name — any term, compared by value."
  @type name :: term()

  @typedoc "A zero-arity endpoint check returning `:ok` or `{:error, reason}`."
  @type check_fun :: (-> :ok | {:error, term()})

  @typedoc "The status of a cluster on the most recent poll."
  @type status :: :up | :down

  # ---------------------------------------------------------------------------
  # Public API
  # ---------------------------------------------------------------------------

  @doc """
  Starts and links the singleton monitor.

  `opts` is a keyword list defaulting to `[]`. The process is registered under
  `ClusterMonitor` unless a `:name` option overrides it; the convenience functions
  always target `ClusterMonitor`. A freshly started server tracks zero clusters.
  """
  @spec start_link(keyword()) :: GenServer.on_start()
  def start_link(opts \\ []) when is_list(opts) do
    name = Keyword.get(opts, :name, __MODULE__)
    GenServer.start_link(__MODULE__, :ok, name: name)
  end

  @doc """
  Registers (or replaces) a cluster under `name`.

  `check_funcs` is a non-empty list of zero-arity endpoint functions (its length is
  the cluster `total`), `interval_ms` is a positive integer poll interval, and `opts`
  may contain:

    * `:quorum` — positive integer `Q`; the cluster is `:up` when at least `Q`
      endpoints are healthy. Defaults to a strict majority, `div(total, 2) + 1`.
    * `:notify` — two-arity `notify.(name, healthy_count)` invoked on an `:up` ->
      `:down` transition. Defaults to a no-op.

  Registration does not poll: the cluster starts `:up` with `healthy` equal to
  `total`, and the first poll runs one `interval_ms` later, repeating thereafter.
  Re-registering replaces the whole configuration, resets the status to `:up`, and
  guarantees the previous registration's scheduled polls never run again.

  Raises `FunctionClauseError` when `check_funcs` is not a non-empty list, when
  `interval_ms` is not a positive integer, or when any element of `check_funcs` is
  not a zero-arity function. Returns `:ok`.
  """
  @spec register_cluster(name(), [check_fun(), ...], pos_integer(), keyword()) :: :ok
  def register_cluster(name, check_funcs, interval_ms, opts \\ [])
      when is_list(check_funcs) and check_funcs != [] and
             is_integer(interval_ms) and interval_ms > 0 and is_list(opts) do
    Enum.each(check_funcs, &ensure_zero_arity!/1)
    GenServer.call(__MODULE__, {:register, name, check_funcs, interval_ms, opts})
  end

  @doc """
  Synchronously performs exactly one poll for the named cluster right now.

  Identical work to a scheduled tick: calls every endpoint, recomputes
  `healthy`/status, and fires the notify function on an `:up` -> `:down` transition.
  Does not alter or reschedule the periodic timer. Returns `{:ok, status}` with the
  resulting status, or `{:error, :not_found}` if the cluster is unknown.
  """
