  test "index survives a graceful restart", %{dir: dir} do
    {:ok, pid} = InvertedIndex.start_link(dir: dir)
    :ok = InvertedIndex.index(pid, "d1", %{body: "alpha beta"})
    :ok = InvertedIndex.index(pid, "d2", %{body: "beta gamma"})
