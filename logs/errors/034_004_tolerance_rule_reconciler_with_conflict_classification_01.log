  @type entry :: %{key: key_map(), left: record(), right: record(), differences: diff_map()}
  @type result :: %{
          identical: [entry()],
          within_tolerance: [entry()],
          conflicts: [entry()],
          only_in_left: [record()],
          only_in_right: [record()]
        }
