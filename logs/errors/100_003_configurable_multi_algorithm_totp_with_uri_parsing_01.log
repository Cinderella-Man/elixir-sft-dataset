    step = div(time, period)
    message = <<step::unsigned-big-integer-size(64)>>
    hmac = :crypto.mac(:hmac, crypto_hash(algorithm), key, message)

    hmac
    |> truncate(digits)
    |> Integer.to_string()
    |> String.pad_leading(digits, "0")
  end

