      ...>   MultiSourceReconciler.reconcile(
      ...>     %{crm: crm, billing: billing},
      ...>     key_fields: [:id]
      ...>   )
      iex> entry.key
      %{id: 1}
      iex> entry.conflicts
      %{name: %{crm: "Ada", billing: "Ada Lovelace"}}

