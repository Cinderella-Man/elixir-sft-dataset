      {:ok, pid} = StreamReconciler.start_link(key_fields: [:id])
      :ok = StreamReconciler.push_left(pid, %{id: 1, name: "a"})
      :ok = StreamReconciler.push_right(pid, %{id: 1, name: "b"})
