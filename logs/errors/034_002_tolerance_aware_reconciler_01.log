  # ---------------------------------------------------------------------------

  defp diff(left, right, fields, comparators) do
    Enum.reduce(fields, %{}, fn field, acc ->
      lv = Map.get(left, field)
      rv = Map.get(right, field)
      rule = Map.get(comparators, field, :exact)

