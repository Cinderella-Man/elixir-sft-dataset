      iex> state = Reconciler.put_left(state, %{id: 1, name: "a"})
      iex> state = Reconciler.put_right(state, %{id: 1, name: "b"})
      iex> res = Reconciler.result(state)
      iex> res.matched
      [%{left: %{id: 1, name: "a"}, right: %{id: 1, name: "b"},
         differences: %{name: %{left: "a", right: "b"}}}]

