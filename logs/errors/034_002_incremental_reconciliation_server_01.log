      only_in_left: Enum.map(only_left_keys, &Map.fetch!(left, &1)),
      only_in_right: Enum.map(only_right_keys, &Map.fetch!(right, &1))
    }
  end

  @spec compute_differences(record(), record(), map()) :: diff_map()
  defp compute_differences(left_record, right_record, state) do
