    rules = %{a: [:not_null]}
    records = [%{a: 1}, %{a: nil}, %{}]
    result = DataQualityScorer.score(records, rules)

    [r1, r2, r3] = result.records
    assert r1.passed == 1
    assert r2.passed == 0
    assert r3.passed == 0

    # 1 of 3 records passes the field
