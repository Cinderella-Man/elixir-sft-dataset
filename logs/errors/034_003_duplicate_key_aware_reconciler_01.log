  # ---------------------------------------------------------------------------

  defp classify(acc, key, key_fields, lrecs, rrecs, compare_fields_opt) do
    lcount = length(lrecs)
    rcount = length(rrecs)

    cond do
      lcount > 1 or rcount > 1 ->
        entry = %{key: key_map(key, key_fields), left_count: lcount, right_count: rcount}
