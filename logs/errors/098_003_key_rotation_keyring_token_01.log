      iex> token = KeyringToken.generate(%{user: 1}, keyring, "k1", 60)
      iex> KeyringToken.verify(token, keyring)
      {:ok, %{user: 1}}
  """
  @spec generate(term(), keyring(), binary(), pos_integer()) :: binary()
