  @spec parse_uri(String.t()) :: {:ok, map()} | {:error, atom()}
  def parse_uri(uri) do
    case URI.parse(uri) do
      %URI{scheme: "otpauth", host: "totp", path: path, query: query}
      when is_binary(path) ->
