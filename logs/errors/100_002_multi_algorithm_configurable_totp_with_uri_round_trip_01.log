               issuer: Map.get(params, "issuer", label_issuer),
               account_name: account_name,
               algorithm: algorithm,
               digits: params |> Map.get("digits", "6") |> String.to_integer(),
               period: params |> Map.get("period", "30") |> String.to_integer()
