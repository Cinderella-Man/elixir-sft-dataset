        2 -> raise "boom"
        n -> n * 10
      end)
      # => [%{item: 1, result: {:ok, 10}, worker_id: 0},
      #     %{item: 2, result: {:error, %{kind: :error, reason: "boom"}}, worker_id: 0},
      #     %{item: 3, result: {:ok, 30}, worker_id: 1}]   (order varies)
  """

  @type tagged_result :: {:ok, any()} | {:error, %{kind: :error | :throw | :exit, reason: any()}}

  # ---------------------------------------------------------------------------
  # Public API
  # ---------------------------------------------------------------------------

  @doc """
