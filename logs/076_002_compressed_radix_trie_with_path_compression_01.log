          # whole edge label is consumed — descend into the child
          plen == llen ->
            {new_child, added} = do_insert(child, drop(word, plen))
            new_edge = %{edge | child: new_child}
            {%{node | edges: Map.put(node.edges, key, new_edge)}, added}

