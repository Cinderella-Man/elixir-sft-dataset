  repository to the SQLite3 adapter. It exposes the standard `Ecto.Repo`
  callbacks (all generated by `use Ecto.Repo`).
  """

  use Ecto.Repo,
    otp_app: :state_machine,
    adapter: Ecto.Adapters.SQLite3
end

