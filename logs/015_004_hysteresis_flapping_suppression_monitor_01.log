defmodule StabilityMonitor do
  @moduledoc """
  A `GenServer` that supervises registered services by periodically invoking a
  zero-arity check function for each one and reporting a **confirmed** `:up`/`:down`
  state.

  The confirmed state changes only after a service has been *consistently* failing
  (for `:fail_confirm` checks in a row) or *consistently* recovering (for
  `:ok_confirm` checks in a row). Because a result opposite to the current confirmed
  state resets the streak that was building toward a transition, a service that
  alternates between success and failure — "flapping" — never changes its confirmed
  state. This hysteresis is the core behaviour of the module.

  `StabilityMonitor` is a singleton: it registers itself under the name
  `StabilityMonitor` (i.e. `__MODULE__`) and the convenience API
  (`watch/4`, `force_check/1`, `state/1`, `states/0`, `unwatch/1`) takes no server
  argument, always targeting that registered process.

  Only the OTP standard library is used; there are no external dependencies.
  """

  use GenServer

  @typedoc "A registered service key. Any term may be used."
  @type name :: term()

  @typedoc "The result returned by a service check function."
  @type check_result :: :ok | {:error, term()}

  @typedoc "A zero-arity health check function."
  @type check_func :: (-> check_result())

  @typedoc "A confirmed service state."
  @type confirmed :: :up | :down

  @typedoc "A callback fired on a confirmed state transition."
  @type on_transition :: (name(), confirmed(), confirmed() -> any())

  ## ----------------------------------------------------------------------------
  ## Public API
  ## ----------------------------------------------------------------------------

  @doc """
  Start and link the monitor.

  `opts` is a keyword list (default `[]`). The process is registered under the name
  `StabilityMonitor` unless a `:name` option overrides it; the convenience API always
  targets `StabilityMonitor`. A freshly started server tracks zero services.
  """
  @spec start_link(keyword()) :: GenServer.on_start()
  def start_link(opts \\ []) when is_list(opts) do
    {name, opts} = Keyword.pop(opts, :name, __MODULE__)
    GenServer.start_link(__MODULE__, opts, name: name)
  end

  @doc """
  Register (or re-register) a service to be watched.

  `name` is any term used as the key. `check_func` is a zero-arity function returning
  `:ok` or `{:error, reason}`. `interval_ms` is a positive integer giving the polling
  period; the first check runs one `interval_ms` after registration.

  Options:

    * `:fail_confirm` — positive integer, consecutive failures to confirm `:down`
      (default `3`).
    * `:ok_confirm` — positive integer, consecutive successes to confirm `:up`
      (default `2`).
    * `:on_transition` — a three-arity `fun.(name, from, to)` fired on each confirmed
      transition (default no-op).

  Registration starts the confirmed state at `:up` with both streaks at `0`.
  Re-watching an existing `name` replaces its configuration and resets its state; any
  previously scheduled check for that name is superseded and never runs again.

  Returns `:ok`.
  """
  @spec watch(name(), check_func(), pos_integer(), keyword()) :: :ok
  def watch(name, check_func, interval_ms, opts \\ [])
      when is_function(check_func, 0) and is_integer(interval_ms) and interval_ms > 0 and
             is_list(opts) do
    GenServer.call(__MODULE__, {:watch, name, check_func, interval_ms, opts})
  end

  @doc """
  Synchronously perform exactly one check for `name` immediately.

  Does identical work to a scheduled tick — calling the check function, updating the
  streaks and confirmed state, and firing `:on_transition` on a confirmed change —
  but does not alter or reschedule the periodic timer.

  Returns `{:ok, state}` with the resulting confirmed state, or
  `{:error, :not_found}` if `name` is not registered.
  """
  @spec force_check(name()) :: {:ok, confirmed()} | {:error, :not_found}
  def force_check(name) do
    GenServer.call(__MODULE__, {:force_check, name})
  end

  @doc """
  Return the confirmed state (`:up` or `:down`) for `name`, or `{:error, :not_found}`
  if the service is unknown.
  """
  @spec state(name()) :: confirmed() | {:error, :not_found}
  def state(name) do
    GenServer.call(__MODULE__, {:state, name})
  end

  @doc """
  Return a map of `%{name => state}` for every registered service, or `%{}` when none
  are registered.
  """
  @spec states() :: %{optional(name()) => confirmed()}
  def states do
    GenServer.call(__MODULE__, :states)
  end

  @doc """
  Remove `name` from monitoring.

  Returns `:ok` if the service existed (its scheduled checks never run again), or
  `{:error, :not_found}` if it was not registered.
  """
  @spec unwatch(name()) :: :ok | {:error, :not_found}
  def unwatch(name) do
    GenServer.call(__MODULE__, {:unwatch, name})
  end

  ## ----------------------------------------------------------------------------
  ## GenServer callbacks
  ## ----------------------------------------------------------------------------

  @impl true
  @spec init(keyword()) :: {:ok, %{services: map()}}
  def init(_opts) do
    {:ok, %{services: %{}}}
  end

  @impl true
  def handle_call({:watch, name, check_func, interval_ms, opts}, _from, state) do
    fail_confirm = fetch_pos_integer(opts, :fail_confirm, 3)
    ok_confirm = fetch_pos_integer(opts, :ok_confirm, 2)
    on_transition = Keyword.get(opts, :on_transition, &default_on_transition/3)
    gen = make_ref()

    service = %{
      check_func: check_func,
      interval_ms: interval_ms,
      fail_confirm: fail_confirm,
      ok_confirm: ok_confirm,
      on_transition: on_transition,
      confirmed: :up,
      fail_streak: 0,
      ok_streak: 0,
      gen: gen
    }

    schedule(name, gen, interval_ms)
    services = Map.put(state.services, name, service)
    {:reply, :ok, %{state | services: services}}
  end

  def handle_call({:force_check, name}, _from, state) do
    case Map.fetch(state.services, name) do
      {:ok, service} ->
        updated = perform_check(name, service)
        services = Map.put(state.services, name, updated)
        {:reply, {:ok, updated.confirmed}, %{state | services: services}}

      :error ->
        {:reply, {:error, :not_found}, state}
    end
  end

  def handle_call({:state, name}, _from, state) do
    case Map.fetch(state.services, name) do
      {:ok, service} -> {:reply, service.confirmed, state}
      :error -> {:reply, {:error, :not_found}, state}
    end
  end

  def handle_call(:states, _from, state) do
    reply = Map.new(state.services, fn {name, service} -> {name, service.confirmed} end)
    {:reply, reply, state}
  end

  def handle_call({:unwatch, name}, _from, state) do
    case Map.fetch(state.services, name) do
      {:ok, _service} ->
        services = Map.delete(state.services, name)
        {:reply, :ok, %{state | services: services}}

      :error ->
        {:reply, {:error, :not_found}, state}
    end
  end

  def handle_call(_other, _from, state) do
    {:reply, {:error, :bad_request}, state}
  end

  @impl true
  def handle_info({:check, name, gen}, state) do
    case Map.fetch(state.services, name) do
      {:ok, %{gen: ^gen} = service} ->
        updated = perform_check(name, service)
        schedule(name, gen, updated.interval_ms)
        services = Map.put(state.services, name, updated)
        {:noreply, %{state | services: services}}

      _superseded_or_missing ->
        {:noreply, state}
    end
  end

  def handle_info(_other, state) do
    {:noreply, state}
  end

  ## ----------------------------------------------------------------------------
  ## Internal helpers
  ## ----------------------------------------------------------------------------

  @spec schedule(name(), reference(), pos_integer()) :: reference()
  defp schedule(name, gen, interval_ms) do
    Process.send_after(self(), {:check, name, gen}, interval_ms)
  end

  @spec perform_check(name(), map()) :: map()
