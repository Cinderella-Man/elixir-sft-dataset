      :pending ->
        case persist(state.repo, entity_id, :expire, :pending, :cancelled) do
          :ok ->
            new_states = Map.put(state.states, entity_id, :cancelled)
            {:noreply, %{state | states: new_states}}

          {:error, _reason} ->
            {:noreply, state}
        end

