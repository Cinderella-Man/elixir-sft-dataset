    %{state | access: Map.put(state.access, key, state.clock), clock: state.clock + 1}
  end

  defp evict_lru(f, r, a) do
    {lru_key, _tick} = Enum.min_by(a, fn {_k, tick} -> tick end)
    value = Map.fetch!(f, lru_key)
