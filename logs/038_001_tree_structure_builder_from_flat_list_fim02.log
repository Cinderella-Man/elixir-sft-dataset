      ...>   %{id: 3, parent_id: 2,    name: "grandchild"},
      ...> ]
      iex> {:ok, [root]} = TreeBuilder.build(items)
      iex> root.name
      "root"
      iex> [child] = root.children
      iex> child.name
      "child"
      iex> [grandchild] = child.children
      iex> grandchild.name
      "grandchild"
  """

