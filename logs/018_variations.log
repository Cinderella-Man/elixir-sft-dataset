defmodule CascadeCrud.Archive do
  @moduledoc """
  In-memory hierarchical archive store: a tree of folders and files with
  cascading archive (soft delete) and origin-aware restore.
  """

  use GenServer

  @type id :: pos_integer()
  @type node_map :: %{
          id: id(),
          type: :folder | :file,
          name: String.t(),
          parent_id: id() | nil,
          content: String.t() | nil,
          archived_at: DateTime.t() | nil,
          archive_origin: :direct | :cascade | nil
        }

  # ---------------------------------------------------------------
  # Client API
  # ---------------------------------------------------------------

  @spec start_link(keyword()) :: GenServer.on_start()
  def start_link(opts) do
    case Keyword.fetch(opts, :name) do
      {:ok, name} -> GenServer.start_link(__MODULE__, opts, name: name)
      :error -> GenServer.start_link(__MODULE__, opts)
    end
  end

  @spec create_folder(GenServer.server(), map()) :: {:ok, node_map()} | {:error, atom()}
  def create_folder(server, attrs), do: GenServer.call(server, {:create, :folder, attrs})

  @spec create_file(GenServer.server(), map()) :: {:ok, node_map()} | {:error, atom()}
  def create_file(server, attrs), do: GenServer.call(server, {:create, :file, attrs})

  @spec fetch_node(GenServer.server(), id(), keyword()) :: {:ok, node_map()} | {:error, atom()}
  def fetch_node(server, id, opts \\ []), do: GenServer.call(server, {:fetch_node, id, opts})

  @spec list_children(GenServer.server(), id(), keyword()) ::
          {:ok, [node_map()]} | {:error, atom()}
  def list_children(server, folder_id, opts \\ []),
    do: GenS (truncated)
