  @typedoc "A GenServer reference (pid or registered name)."
  @type server :: GenServer.server()

  @typedoc "A lowercase hexadecimal SHA-1 digest."
  @type hash :: String.t()

  @typedoc "A single commit description returned by `log/2`."
  @type entry :: %{
          hash: hash(),
          tree: hash(),
          parents: [hash()],
          author: String.t(),
          message: String.t()
        }

