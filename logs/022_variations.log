    |> put_req_header("authorization", "Bearer #{token}")
    |> put_req_header("content-type", "application/json")
    |> call(store)
  end

  defp post_accept(store, team_id, user_id, token) do
    :post
    |> conn("/api/teams/#{team_id}/invitations/#{user_id}/accept", "")
