  @type interval :: {integer(), integer()}

  # -------------------------------------------------------------------------
  # Client API
  # -------------------------------------------------------------------------

  @doc """
  Starts the registry server.

  Accepts standard `GenServer` options (e.g. `:name`) and returns
  `{:ok, pid}` on success.
  """
