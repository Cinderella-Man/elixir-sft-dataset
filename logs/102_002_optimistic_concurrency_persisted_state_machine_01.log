    StateMachine.MigrationRepo.query!(
      "INSERT INTO entity_transitions " <>
        "(entity_id, event, from_state, to_state, version, inserted_at) " <>
        "VALUES ('m:1', 'confirm', 'pending', 'confirmed', 1, '2026-01-01 00:00:00')",
      []
