<file path="solution.ex">
defmodule HealthMonitor do
  @moduledoc """
  A `GenServer` that supervises a set of registered *probes*, running each
  probe's check function on a periodic interval and tracking a three-level
  **severity** for every probe: `:ok`, `:warning`, or `:critical`.

  A probe's severity is driven purely by how many checks have failed in a row.
  Each successful check resets the consecutive-failure count to zero; each
  failing check increments it. The resulting level is derived solely from the
  count and the probe's `:warn_after`/`:crit_after` thresholds. Whenever the
  level *changes*, the probe's `:on_change` callback fires exactly once.

  `HealthMonitor` is a singleton, registered under the module name
  `HealthMonitor`. The convenience functions (`add_probe/4`, `level/1`,
  `report/0`, `probe_now/1`, `remove_probe/1`) take no server argument and
  always target that registered process.

  Only the OTP standard library is used; there are no external dependencies.
  """

  use GenServer

  @typedoc "A probe severity level."
  @type level :: :ok | :warning | :critical

  @typedoc "A zero-arity health check returning `:ok` or `{:error, reason}`."
  @type check_func :: (-> :ok | {:error, term()})

  @typedoc "Callback invoked as `on_change.(name, old_level, new_level, reason)`."
  @type on_change :: (term(), level(), level(), term() | nil -> any())

  # ── Public API ────────────────────────────────────────────────────────────

  @doc """
  Starts and links the singleton monitor process.

  `opts` is a keyword list (defaulting to `[]`). The process is registered under
  the name `HealthMonitor` unless a `:name` option overrides it; the convenience
  functions always target `HealthMonitor`. A freshly started server tracks zero
  probes.
  """
  @spec start_link(keyword()) :: GenServer.on_start()
  def start_link(opts \\ []) do
    name = Keyword.get(opts, :name, __MODULE__)
    GenServer.start_link(__MODULE__, opts, name: name)
  end

  @doc """
  Registers (or replaces) a probe named `name`.

  `check_func` is a zero-arity function returning `:ok` or `{:error, reason}`.
  `interval_ms` is a positive integer giving how often, in milliseconds, the
  check runs after registration. The first check happens one `interval_ms`
  later, then repeats.

  Options:

    * `:warn_after` — positive integer, defaults to `2`.
    * `:crit_after` — positive integer, defaults to `4`.
    * `:on_change` — four-arity callback, defaults to a no-op.

  The probe starts at level `:ok` with a failure count of `0`. Re-adding an
  existing `name` replaces its configuration and resets its level and count;
  any previously scheduled checks for that probe never run again. Returns `:ok`.
  """
  @spec add_probe(term(), check_func(), pos_integer(), keyword()) :: :ok
  def add_probe(name, check_func, interval_ms, opts \\ [])
      when is_function(check_func, 0) and is_integer(interval_ms) and interval_ms > 0 do
    GenServer.call(__MODULE__, {:add_probe, name, check_func, interval_ms, opts})
  end

  @doc """
  Returns the current level of the probe named `name`.

  Returns `:ok`, `:warning`, or `:critical`, or `{:error, :not_found}` if no
  such probe is registered.
  """
  @spec level(term()) :: level() | {:error, :not_found}
  def level(name), do: GenServer.call(__MODULE__, {:level, name})

  @doc """
  Returns a map `%{name => level}` of every registered probe and its level.

  Returns `%{}` when no probes are registered.
  """
  @spec report() :: %{optional(term()) => level()}
  def report, do: GenServer.call(__MODULE__, :report)

  @doc """
  Synchronously performs exactly one check for the probe named `name`.

  This does identical work to a scheduled interval tick — it calls the check
  function, updates the failure count and level, and fires `on_change` on a
  level change — but does not alter or reschedule the periodic timer. Returns
  `{:ok, level}`, or `{:error, :not_found}` if the probe is unknown.
  """
  @spec probe_now(term()) :: {:ok, level()} | {:error, :not_found}
  def probe_now(name), do: GenServer.call(__MODULE__, {:probe_now, name})

  @doc """
  Removes the probe named `name`.

  Returns `:ok` if the probe existed (after which it no longer appears in
  `report/0` and its scheduled checks never run again), or `{:error, :not_found}`
  if no such probe was registered.
  """
  @spec remove_probe(term()) :: :ok | {:error, :not_found}
  def remove_probe(name), do: GenServer.call(__MODULE__, {:remove_probe, name})

  # ── GenServer callbacks ───────────────────────────────────────────────────

  @impl true
  @spec init(keyword()) :: {:ok, map()}
  def init(_opts), do: {:ok, %{}}

  @impl true
  def handle_call({:add_probe, name, check_func, interval_ms, opts}, _from, state) do
    gen = make_ref()

    probe = %{
      check_func: check_func,
      interval: interval_ms,
      warn_after: Keyword.get(opts, :warn_after, 2),
      crit_after: Keyword.get(opts, :crit_after, 4),
      on_change: Keyword.get(opts, :on_change, fn _n, _o, _new, _r -> :ok end),
      level: :ok,
      fail_count: 0,
      gen: gen
    }

    schedule(name, gen, interval_ms)
    {:reply, :ok, Map.put(state, name, probe)}
  end

  def handle_call({:level, name}, _from, state) do
    case Map.get(state, name) do
      nil -> {:reply, {:error, :not_found}, state}
      probe -> {:reply, probe.level, state}
    end
  end

  def handle_call(:report, _from, state) do
    report = Map.new(state, fn {name, probe} -> {name, probe.level} end)
    {:reply, report, state}
  end

  def handle_call({:probe_now, name}, _from, state) do
    case Map.get(state, name) do
      nil ->
        {:reply, {:error, :not_found}, state}

      probe ->
        probe = perform_check(name, probe)
        {:reply, {:ok, probe.level}, Map.put(state, name, probe)}
    end
  end

  def handle_call({:remove_probe, name}, _from, state) do
    case Map.pop(state, name) do
      {nil, _state} -> {:reply, {:error, :not_found}, state}
      {_probe, new_state} -> {:reply, :ok, new_state}
    end
  end

  @impl true
  def handle_info({:check, name, gen}, state) do
    case Map.get(state, name) do
      %{gen: ^gen} = probe ->
        probe = perform_check(name, probe)
        schedule(name, gen, probe.interval)
        {:noreply, Map.put(state, name, probe)}

      _ ->
        {:noreply, state}
    end
  end

  def handle_info(_msg, state), do: {:noreply, state}

  # ── Internal helpers ──────────────────────────────────────────────────────

  @spec schedule(term(), reference(), pos_integer()) :: reference()
  defp schedule(name, gen, interval) do
    Process.send_after(self(), {:check, name, gen}, interval)
  end

  @spec perform_check(term(), map()) :: map()
  defp perform_check(name, probe) do
    old_level = probe.level

    {new_count, new_level, reason} =
      case probe.check_func.() do
        :ok ->
          {0, :ok, nil}

        {:error, reason} ->
          count = probe.fail_count + 1
          {count, level_for(count, probe.warn_after, probe.crit_after), reason}
      end

    if new_level != old_level do
      probe.on_change.(name, old_level, new_level, reason)
    end

    %{probe | fail_count: new_count, level: new_level}
  end

  @spec level_for(non_neg_integer(), pos_integer(), pos_integer()) :: level()
  defp level_for(count, warn_after, crit_after) do
    cond do
      count >= crit_after -> :critical
      count >= warn_after -> :warning
      true -> :ok
    end
  end
end
