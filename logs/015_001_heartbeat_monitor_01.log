defmodule MonitorTest do
  use ExUnit.Case, async: false

  setup do
    start_supervised!({Monitor, []})
    :ok
  end

  # ------------------------------------------------------------------
  # Small mailbox helpers for the timer-based lifecycle test
  # -- (truncated)
