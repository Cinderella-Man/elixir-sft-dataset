defmodule Monitor do
  @moduledoc """
  A singleton `GenServer` that supervises registered services by periodically
  invoking a per-service check function, tracking each service's `:up`/`:down`
  status, and firing a notification when a service transitions from `:up` to
  `:down`.

  The process is registered under the module name `Monitor`, so the convenience
  functions (`register/4`, `status/1`, `statuses/0`, `check_now/1`) take no
  server argument and always target that named process.

  Each registration is tagged with a generation token (a `make_ref/0`). Only
  scheduled check messages whose token matches the service's current registration
  are honoured, so superseded timer chains from a prior registration are inert.

  Only the OTP standard library is used; there are no external dependencies.
  """

  use GenServer

  @type service_name :: term()
  @type status :: :up | :down
  @type check_fun :: (-> :ok | {:error, term()})
  @type notify_fun :: (service_name(), term() -> any())

  @default_threshold 3

  # --- Public API --------------------------------------------------------------

  @doc """
  Starts and links the monitor process.

  `opts` is a keyword list. A `:name` entry overrides the registered name, but
  the convenience functions always target `Monitor`. A freshly started server
  tracks zero services.
  """
  @spec start_link(keyword()) :: GenServer.on_start()
  def start_link(opts \\ []) do
    {name, rest} = Keyword.pop(opts, :name, __MODULE__)
    GenServer.start_link(__MODULE__, rest, name: name)
  end

  @doc """
  Registers (or re-registers) a service under `service_name`.

  `check_func` is a zero-arity function returning `:ok` or `{:error, reason}`.
  `interval_ms` is a positive integer giving the delay before the first check and
  the period between subsequent checks.

  Options:

    * `:threshold` — positive integer `N`; the service is marked `:down` after
      `N` consecutive failed checks (default `#{@default_threshold}`).
    * `:notify` — two-arity function `notify.(service_name, reason)` invoked on an
      `:up` -> `:down` transition (default: no-op).

  Re-registering replaces the configuration and resets the status to `:up` with a
  failure count of `0`; the previous registration's scheduled checks never run
  again. Registration itself does not run the check function.
  """
  @spec register(service_name(), check_fun(), pos_integer(), keyword()) :: :ok
  def register(service_name, check_func, interval_ms, opts \\ [])
      when is_function(check_func, 0) and is_integer(interval_ms) and interval_ms > 0 do
    threshold = Keyword.get(opts, :threshold, @default_threshold)
    notify = Keyword.get(opts, :notify, &default_notify/2)
    GenServer.call(__MODULE__, {:register, service_name, check_func, interval_ms, threshold, notify})
  end

  @doc """
  Synchronously performs exactly one check for `service_name`, identical to a
  scheduled interval tick (calling the check function, updating the failure count
  and status, and firing the notify function on an `:up` -> `:down` transition).

  Returns `{:ok, status}` with the resulting status, or `{:error, :not_found}` if
  the service is unknown. Does not alter or reschedule the periodic timer.
  """
  @spec check_now(service_name()) :: {:ok, status()} | {:error, :not_found}
  def check_now(service_name) do
    GenServer.call(__MODULE__, {:check_now, service_name})
  end

  @doc """
  Returns the current status (`:up` or `:down`) for `service_name`, or
  `{:error, :not_found}` if the service is unknown.
  """
  @spec status(service_name()) :: status() | {:error, :not_found}
  def status(service_name) do
    GenServer.call(__MODULE__, {:status, service_name})
  end

  @doc """
  Returns a map of `%{service_name => status}` for every registered service.
  Returns `%{}` when nothing is registered.
  """
  @spec statuses() :: %{optional(service_name()) => status()}
  def statuses do
    GenServer.call(__MODULE__, :statuses)
  end

  # --- GenServer callbacks -----------------------------------------------------

  @impl true
  @spec init(keyword()) :: {:ok, map()}
  def init(_opts) do
    {:ok, %{services: %{}}}
  end

  @impl true
  def handle_call({:register, name, check, interval, threshold, notify}, _from, state) do
    gen = make_ref()

    service = %{
      check: check,
      interval: interval,
      threshold: threshold,
      notify: notify,
      status: :up,
      failures: 0,
      gen: gen
    }

    Process.send_after(self(), {:check, name, gen}, interval)
    {:reply, :ok, %{state | services: Map.put(state.services, name, service)}}
  end

  def handle_call({:check_now, name}, _from, state) do
    case Map.fetch(state.services, name) do
      {:ok, service} ->
        updated = perform_check(name, service)
        new_state = %{state | services: Map.put(state.services, name, updated)}
        {:reply, {:ok, updated.status}, new_state}

      :error ->
        {:reply, {:error, :not_found}, state}
    end
  end

  def handle_call({:status, name}, _from, state) do
    case Map.fetch(state.services, name) do
      {:ok, service} -> {:reply, service.status, state}
      :error -> {:reply, {:error, :not_found}, state}
    end
  end

  def handle_call(:statuses, _from, state) do
    result = Map.new(state.services, fn {name, service} -> {name, service.status} end)
    {:reply, result, state}
  end

  @impl true
  def handle_info({:check, name, gen}, state) do
    case Map.fetch(state.services, name) do
      {:ok, %{gen: ^gen} = service} ->
        updated = perform_check(name, service)
        Process.send_after(self(), {:check, name, gen}, updated.interval)
        {:noreply, %{state | services: Map.put(state.services, name, updated)}}

      _other ->
        {:noreply, state}
    end
  end

  def handle_info(_msg, state) do
    {:noreply, state}
  end

  # --- Internal helpers --------------------------------------------------------

  @spec perform_check(service_name(), map()) :: map()
  defp perform_check(name, service) do
    case service.check.() do
      :ok ->
        %{service | failures: 0, status: :up}

      {:error, reason} ->
        failures = service.failures + 1

        if failures >= service.threshold and service.status == :up do
          service.notify.(name, reason)
          %{service | failures: failures, status: :down}
        else
          %{service | failures: failures}
        end
    end
  end

  @spec default_notify(service_name(), term()) :: :ok
  defp default_notify(_service_name, _reason), do: :ok
end
